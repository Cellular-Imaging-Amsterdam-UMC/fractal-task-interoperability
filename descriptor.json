{
  "name": "Fractal-Cellpose-SAM-Segmentation",
  "description": "Cell segmentation using Fractal Cellpose-SAM library on ZARR files (CPU-only, minimal wrapper)",
  "container-image": {
    "image": "cellularimagingcf/fractal-cellpose-sam-biaflows",
    "type": "docker"
  },
  "command-line": "python wrapper.py --infolder [INFOLDER] --outfolder [OUTFOLDER] --gtfolder [GTFOLDER] --local -nmc --nuc_channel [NUC_CHANNEL] --diameter [DIAMETER] --prob_threshold [PROB_THRESHOLD] --flow_threshold [FLOW_THRESHOLD] --min_size [MIN_SIZE] [USE_GPU] --cp_model [CP_MODEL] --label_name [LABEL_NAME] [EXCLUDE_ON_EDGES] [DO_3D] --anisotropy [ANISOTROPY] [NORMALIZE]",
  "inputs": [
    {
      "id": "nuc_channel",
      "value-key": "[NUC_CHANNEL]",
      "command-line-flag": "--nuc_channel",
      "name": "Channel for segmentation",
      "description": "Choose channel to segment (start at 0), -1 to use default channel",
      "default-value": 0,
      "optional": true,
      "type": "Number"
    },
    {
      "id": "diameter",
      "value-key": "[DIAMETER]",
      "command-line-flag": "--diameter",
      "name": "Cell diameter",
      "description": "Expected cell diameter in pixels (must be > 0)",
      "default-value": 200,
      "optional": true,
      "type": "Number"
    },
    {
      "id": "prob_threshold",
      "value-key": "[PROB_THRESHOLD]",
      "command-line-flag": "--prob_threshold",
      "name": "Probability threshold, centered at 0.0",
      "description": "Probability threshold, centered at 0.0",
      "default-value": 0.5,
      "optional": true,
      "type": "Number"
    },
    {
      "id": "flow_threshold",
      "value-key": "[FLOW_THRESHOLD]",
      "command-line-flag": "--flow_threshold",
      "name": "Flow threshold",
      "description": "Flow error threshold, 0 turns off this optional QC step. Default: 0.4",
      "default-value": 0.4,
      "optional": true,
      "type": "Number"
    },
    {
      "id": "min_size",
      "value-key": "[MIN_SIZE]",
      "command-line-flag": "--min_size",
      "name": "Minimum size",
      "description": "Minimum number of pixels per mask, can turn off with -1",
      "default-value": 15,
      "optional": true,
      "type": "Number"
    },
    {
      "id": "use_gpu",
      "value-key": "[USE_GPU]",
      "command-line-flag": "--use_gpu",
      "name": "GPU acceleration",
      "description": "Use GPU acceleration if available (CPU-only in this container)",
      "default-value": false,
      "optional": true,
      "type": "Boolean"
    },
    {
      "id": "cp_model",
      "value-key": "[CP_MODEL]",
      "command-line-flag": "--cp_model",
      "name": "Cellpose Model",
      "description": "Use default 'cpsam' model, or specify a custom model name/path",
      "default-value": "cpsam",
      "optional": true,
      "type": "String"
    },
    {
      "id": "label_name",
      "value-key": "[LABEL_NAME]",
      "command-line-flag": "--label_name",
      "name": "Output label name",
      "description": "Name for the output segmentation label in the ZARR file",
      "default-value": "fractal_cellpose_sam_segmentation",
      "optional": true,
      "type": "String"
    },
    {
      "id": "exclude_on_edges",
      "value-key": "[EXCLUDE_ON_EDGES]",
      "command-line-flag": "--exclude_on_edges",
      "name": "Exclude edge cells",
      "description": "Discard masks which touch edges of image",
      "default-value": false,
      "optional": true,
      "type": "Boolean"
    },
    {
      "id": "do_3D",
      "value-key": "[DO_3D]",
      "command-line-flag": "--do_3D",
      "name": "3D processing",
      "description": "Process images as 3D stacks",
      "default-value": false,
      "optional": true,
      "type": "Boolean"
    },
    {
      "id": "anisotropy",
      "value-key": "[ANISOTROPY]",
      "command-line-flag": "--anisotropy",
      "name": "Anisotropy",
      "description": "Anisotropy of volume in 3D (e.g. 2.0 if Z is sampled half as dense as X or Y)",
      "default-value": 1.0,
      "optional": true,
      "type": "Number"
    },
    {
      "id": "normalize",
      "value-key": "[NORMALIZE]",
      "command-line-flag": "--normalize",
      "name": "Normalize intensities",
      "description": "Normalize image intensities before segmentation",
      "default-value": true,
      "optional": true,
      "type": "Boolean"
    }
  ],
  "schema-version": "boutiques-0.5"
}