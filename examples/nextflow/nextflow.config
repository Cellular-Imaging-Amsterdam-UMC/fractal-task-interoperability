/*
 * Nextflow configuration for the Fractal Cellpose-SAM interoperability example.
 *
 * Profiles
 * --------
 * pixi   Use the pre-built pixi environment in the repo root (default for
 *        local development).
 *
 * Usage
 *   nextflow run examples/nextflow/main.nf -profile pixi
 */

// Default parameters
params {
    // Directory where the OME-Zarr dataset will be downloaded / read from.
    dataset_dir = "${projectDir}/../../data_nextflow"

    // Output label name written into the zarr by the task.
    label_name  = "nuclei_nextflow"

    // Overwrite existing label if it already exists.
    overwrite   = true
}

profiles {
    pixi {
        // Point Nextflow at the conda environment that pixi already built.
        // Run `pixi install` in the repo root before launching the pipeline.
        process.conda = "${projectDir}/../../.pixi/envs/default"
    }
}
