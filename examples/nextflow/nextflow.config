/*
 * Nextflow configuration for the Fractal Cellpose-SAM interoperability example.
 *
 * Profiles
 * --------
 * pixi   Use the pre-built pixi environment in the repo root (default for
 *        local development).
 *
 * Usage (from the repo root, after `pixi install`):
 *   nextflow run examples/nextflow/main.nf -profile pixi \
 *       -params-file examples/nextflow/params_example.yml
 */

params {
    zarr_urls                = []    // required — provide via -params-file

    // Optional task parameters — null means "use the task's own manifest default"
    channels                 = null  // required — provide via -params-file
    label_name               = null
    overwrite                = null
    level_path               = null
    iterator_configuration   = null
    custom_model             = null
    advanced_parameters      = null
    pre_post_process         = null
    create_masking_roi_table = null
}

profiles {
    pixi {
        // Point Nextflow at the conda environment that pixi already built.
        // Run `pixi install` in the repo root before launching the pipeline.
        process.conda = "${projectDir}/../../.pixi/envs/default"
    }
}
